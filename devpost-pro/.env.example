# Server-side URL for the FastAPI backend (used by /api/analyze and /api/post).
DEVPOST_BACKEND_URL=http://127.0.0.1:8000

# Optional: only if you call the backend directly from the browser (not required when using Next API routes).
# NEXT_PUBLIC_DEVPOST_BACKEND_URL=http://127.0.0.1:8000

NEXT_PUBLIC_GTM_ID=

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_openssl_rand_base64_32
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Credentials auth (email/password) local data store:
# users are persisted in ./data/users.json
